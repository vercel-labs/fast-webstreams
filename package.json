{
  "name": "experimental-fast-webstreams",
  "version": "0.0.15",
  "type": "module",
  "description": "Exploring faster WebStreams for Node.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "edge-light": "./src/edge.js",
      "workerd": "./src/edge.js",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "bench": "node --expose-gc bench/run.js",
    "bench:quick": "node --expose-gc bench/run.js --iterations=3 --warmup=1",
    "bench:passthrough": "node --expose-gc bench/run.js --scenario=passthrough",
    "bench:next": "npm run --prefix vendor/cf-vs-vercel-bench/next-bench/vercel-edition bench",
    "bench:next:quick": "npm run --prefix vendor/cf-vs-vercel-bench/next-bench/vercel-edition bench:quick",
    "test": "node --test test/*.test.js && node test/run-wpt.js --mode=fast",
    "test:unit": "node --test test/*.test.js",
    "test:wpt": "node test/run-wpt.js --mode=fast",
    "test:wpt:native": "node test/run-wpt.js --mode=native",
    "prepublishOnly": "node test/prepublish.js",
    "knip": "knip",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "webstreams",
    "streams",
    "readable",
    "writable",
    "transform",
    "performance",
    "whatwg"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.28.1",
  "devDependencies": {
    "biome": "^0.3.3",
    "knip": "^5.83.1"
  }
}
